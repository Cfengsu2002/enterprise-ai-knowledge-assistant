# 开发（npm run dev）：默认使用 Vite 代理 /api → 后端，一般不要设置 VITE_API_URL。
# 若仍要浏览器直连 http://localhost:8000，可取消下一行注释并设 VITE_USE_API_PROXY=false
# VITE_API_URL=http://localhost:8000
# VITE_USE_API_PROXY=false

# Docker Compose 里由 compose 注入 VITE_BACKEND_PROXY，无需在此填写。
# 本机仅跑前端、后端在 8000 时，可不设（vite.config 默认代理到 127.0.0.1:8000）。

# 生产构建（npm run build）部署到 CDN 时，再设置实际 API 地址：
# VITE_API_URL=https://api.example.com

# 浏览器直连 S3 报 Failed to fetch（桶 CORS/网络）时，设为 true 强制经后端 /api 上传分片（不经 S3 预签名 PUT）
# VITE_S3_UPLOAD_VIA_PROXY=true
