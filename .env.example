# Database (default matches docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_assistant

# --- Embeddings（小模型本地跑：不设 OPENAI_API_KEY 即可用 FastEmbed + ONNX）---
# auto | openai | local  —  auto：有 Key 用 OpenAI，否则用本地模型
# EMBEDDING_BACKEND=auto
# 更小的英文模型（约百 MB 级，384 维）：BAAI/bge-small-en-v1.5
# LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# 上传后自动切块+写入向量（本地 /upload 与 S3 multipart complete）；设为 false 则只存文件
# AUTO_INDEX_ON_UPLOAD=true
#
# RAG 切块（默认 500 / 50；也可在 index URL 上带 chunk_size、chunk_overlap）
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
#
# 入库与检索（PostgreSQL chunks.embedding JSONB）：
#   POST /rag/documents/{document_id}/index?enterprise_id=1
#   POST /rag/search  body: {"enterprise_id":1,"query":"...","limit":8}
# 新库或首次部署需执行 database/init/009_chunks_embedding.sql（docker init 会自动跑）

# Local uploads (non-S3)
# UPLOAD_DIR=uploads

# --- S3 multipart upload (optional) ---
# Set S3_BUCKET to enable POST /upload/s3/multipart/*
# 使用「真实 AWS S3」时不要设置 S3_ENDPOINT_URL（留空即可）。
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# 仅 MinIO / 自建 S3 兼容服务需要：
# S3_ENDPOINT_URL=http://localhost:9000
# Presigned part URL lifetime (seconds, 300–604800)
# S3_PRESIGN_EXPIRES_SECONDS=3600
